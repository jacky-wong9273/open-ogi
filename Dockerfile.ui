# ── UI (build → nginx) ──────────────────────────────────────
FROM node:22-alpine AS ui-deps
WORKDIR /app
RUN corepack enable
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY shared/package.json shared/
COPY ui/package.json ui/
RUN pnpm install --frozen-lockfile --filter @open-ogi/ui --filter @open-ogi/shared

FROM node:22-alpine AS ui-build
WORKDIR /app
RUN corepack enable
COPY --from=ui-deps /app/node_modules ./node_modules
COPY --from=ui-deps /app/shared/node_modules ./shared/node_modules
COPY --from=ui-deps /app/ui/node_modules ./ui/node_modules
COPY tsconfig.json ./
COPY shared/ shared/
COPY ui/ ui/
RUN cd shared && pnpm run build && cd ../ui && pnpm run build

FROM nginx:alpine AS ui
COPY --from=ui-build /app/ui/dist /usr/share/nginx/html
COPY ui/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
